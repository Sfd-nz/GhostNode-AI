# ==========================================
# GHOSTNODE-AI: MASTER CONFIGURATION (.env)
# ==========================================

# ------------------------------------------
# 1. MQTT BROKER SETTINGS
# ------------------------------------------
# The IP address of the machine running your MQTT broker (Mosquitto, ESP32, etc.).
BROKER_IP="127.0.0.1"

# The standard port for MQTT. Usually 1883 unless you have configured SSL/TLS.
BROKER_PORT=1883

# Login credentials for your broker. Leave blank ("") if no authentication is required.
MQTT_USER=""
MQTT_PASS=""

# The root topic your Meshtastic network uses. 
# TWEAKING: Changing "msh/2/#" to "msh/ANZ/2/#" changes which regional mesh your AI listens to.
LISTEN_TOPIC="msh/2/#"


# ------------------------------------------
# 2. HARDWARE & RADIO SETTINGS
# ------------------------------------------
# The unique Decimal ID of the radio physically connected to your AI server.
# TWEAKING: This is mandatory. If incorrect, the AI will get caught in an infinite loop listening to its own echoes.
HELTEC_NODE_ID_DEC=1234567890

# Which Meshtastic channels are allowed to trigger the AI (0=Primary, 1-7=Secondary).
# TWEAKING: Set to "2,3" to restrict the AI strictly to private tactical channels. Set to "0" to let the public use it.
ALLOWED_AI_CHANNELS=2


# ------------------------------------------
# 3. AI & OLLAMA SETTINGS
# ------------------------------------------
# The local API addresses for your Ollama instance.
OLLAMA_URL="http://localhost:11434/api/chat"
OLLAMA_EMBED_URL="http://localhost:11434/api/embeddings"

# The "Brain" model used to generate text and act out the Personas.
# TWEAKING: Change to a smaller model (e.g., "llama3:8b") for speed, or a larger model (e.g., "dolphin-mixtral") for smarter, uncensored analysis.
OLLAMA_MODEL="llama3"
CODER_MODEL="qwen2.5-coder:7b"

# The "Librarian" model used to mathematically convert text into vector scores for the database.
# TWEAKING WARNING: If you change this model, you MUST delete your chroma_db folder and start over. Different models use different math!
EMBED_MODEL="nomic-embed-text"


# ------------------------------------------
# 4. DATABASE & FILE PATHS
# ------------------------------------------
# Use absolute paths (e.g., "C:/AI/chroma_db" or "/home/pi/AI/chroma_db").
DB_PATH="./chroma_db"

# Put PDF/TXT manuals here. The scraper will read them and move them to PROCESSED_PATH.
DROPZONE_PATH="./Dropzone"
PROCESSED_PATH="./Dropzone/processed"

# The ledger file that prevents the scraper from downloading the same news article twice.
DEDUP_INDEX_FILE="./ingested_urls.json"

# Set to "true" to save a raw offline backup of every website scraped. 
# TWEAKING: Set to "false" to massively save hard drive space.
ARCHIVE_HTML="false"
ARCHIVE_PATH="./ArchiveHTML"


# ------------------------------------------
# 5. SCRAPER & INGESTION TUNING
# ------------------------------------------
# How many days old a news article can be before the AI automatically deletes it.
# TWEAKING: Lower numbers (e.g., 30) keep the AI strictly focused on current events and keep the database fast.
NEWS_PRUNE_DAYS="90"

# How long the scraper sleeps before checking RSS feeds again (7200 seconds = 2 hours).
NEWS_LOOP_SLEEP_SECONDS="7200"

# Number of parallel download threads for the scraper.
# TWEAKING: "1" acts like a stealthy human. "3" or higher downloads incredibly fast but triggers Cloudflare IP bans.
INGEST_WORKERS="1"

# How many words to slice a document into before saving it to the database.
CHUNK_WORDS="170"

# How many words from the previous chunk to repeat in the next chunk.
# TWEAKING: Higher overlap (e.g., 50) preserves context across page breaks, making the AI's reading comprehension much smoother.
CHUNK_OVERLAP_WORDS="35"

MAX_EMBED_CHARS="6500"
UPSERT_BATCH_SIZE="32"


# ------------------------------------------
# 6. VECTOR SEARCH & RAG CALIBRATION
# ------------------------------------------
# How many articles the database initially pulls to search for keywords (like "NZ").
# TWEAKING: Higher limit (e.g., 60) makes the AI smarter at finding obscure regional news, but slightly slower to respond.
FETCH_LIMIT="40"

# How many of those articles are actually handed to the AI Brain.
# TWEAKING: "3" or "4" gives the AI plenty of context. Going above "5" might overload the LLM's short-term memory limit.
TOP_DOCS_RETURNED="4"

# Turn the "Bouncer" on or off to block irrelevant data from confusing the AI.
USE_DISTANCE_FILTER="true"

# The mathematical cutoff score for article relevance.
# TWEAKING: Lower (e.g., 200.0) makes the AI extremely strict, preventing hallucinations but risking "NEGATIVE CONTACT" replies. Higher (e.g., 350.0) is looser, giving the AI more to read but risking irrelevant answers. Check the terminal Calibration Logs to find your perfect number!
MAX_DISTANCE="325.0"
